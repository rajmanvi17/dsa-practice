var pivotIndex = function(nums) {

    let totalSum = 0;

    // step 1: total sum
    for(let num of nums) {
        totalSum += num;
    }

    let leftSum = 0;

    // step 3
    for(let i = 0; i < nums.length; i++) {

        let rightSum = totalSum - leftSum - nums[i];

        if(leftSum === rightSum) {
            return i;  // got pivot
        }

        leftSum += nums[i];
    }

    return -1;
};

(* 
STEPS-
Total sum nikaalo
leftSum = 0 se start karo
Loop chalao:
rightSum = totalSum - leftSum - nums[i]
Agar leftSum === rightSum → return index 
leftSum += nums[i]
Agar kahin match nahi mila → return -1 *)
