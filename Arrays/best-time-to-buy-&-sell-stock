var maxProfit = function(prices) {

    let minPrice = prices[0];  //step 1
    let maxProfit = 0;        //step 2

    for(let i = 0;  i < prices.length; i++) {

        if(prices[i] < minPrice) {
            minPrice = prices[i];
        } else {
            let profit = prices[i] - minPrice;

            if(profit > maxProfit) {
                maxProfit = profit;
            }
        }
    }
