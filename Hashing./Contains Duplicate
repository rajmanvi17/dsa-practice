var containsDuplicate = function(nums) {

    let set = new Set();

    for(let i = 0; i < nums.length; i++) {

        if(set.has(nums[i])) {
            return true;  // duplicate mil gaya 💀
        }

        set.add(nums[i]);
    }

    return false; // koi duplicate nahi mila
};


